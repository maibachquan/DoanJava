<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: #F4F7FC;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController" prefHeight="500.0" prefWidth="700.0">

    <VBox alignment="CENTER" spacing="20.0" maxWidth="400.0" maxHeight="380.0" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.08), 25, 0, 0, 10);">
        <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/></padding>

        <Label text="ĐĂNG NHẬP" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
        <Label text="Chào mừng đại ca trở lại hệ thống" style="-fx-text-fill: #64748B; -fx-font-size: 13px; -fx-padding: 0 0 10 0;"/>

        <VBox spacing="8.0">
            <Label text="Tài khoản:" style="-fx-font-weight: bold; -fx-text-fill: #334155;"/>
            <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập..." style="-fx-padding: 12px; -fx-background-radius: 8px; -fx-border-color: #CBD5E1; -fx-border-radius: 8px; -fx-background-color: #F8FAFC; -fx-font-size: 14px;"/>
        </VBox>

        <VBox spacing="8.0">
            <Label text="Mật khẩu:" style="-fx-font-weight: bold; -fx-text-fill: #334155;"/>
            <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu..." style="-fx-padding: 12px; -fx-background-radius: 8px; -fx-border-color: #CBD5E1; -fx-border-radius: 8px; -fx-background-color: #F8FAFC; -fx-font-size: 14px;"/>
        </VBox>

        <Label fx:id="lblMessage" textFill="#EF4444" wrapText="true" style="-fx-font-weight: bold;"/>

        <Button text="Đăng nhập" onAction="#handleLogin" maxWidth="Infinity" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-padding: 12px; -fx-background-radius: 8px; -fx-cursor: hand;"/>

        <HBox alignment="CENTER" spacing="5.0" style="-fx-padding: 10px 0 0 0;">
            <Label text="Chưa có tài khoản?" style="-fx-text-fill: #64748B;"/>
            <Button text="Đăng ký ngay" onAction="#handleRegister" style="-fx-background-color: transparent; -fx-text-fill: #3B82F6; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0;"/>
        </HBox>
    </VBox>
</StackPane>